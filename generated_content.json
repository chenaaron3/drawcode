"{\"lesson_json\":\"{\\\"id\\\":\\\"initialize-variables\\\",\\\"title\\\":\\\"Initialize Variables\\\",\\\"description\\\":\\\"Set up character attributes\\\",\\\"template\\\":\\\"# Initialize your character's attributes here\\\\nk = 88  # Value representing your character's level\\\\nPI = 3.14  # Value representing a special magic number\\\\nname = 'Bob'  # Your character's name\\\\n\\\\n# Don't change the line below\\\\nprint(f'Level = {k}')\\\\nprint(f'Magic Number = {PI}')\\\\nprint(f'Character Name = {name}')\\\\n\\\",\\\"solution\\\":\\\"k = 88\\\\nPI = 3.14\\\\nname = 'Bob'\\\\n\\\",\\\"entrypoint\\\":\\\"\\\",\\\"inputs\\\":{},\\\"time\\\":1,\\\"mode\\\":\\\"line\\\"}\",\"lesson_markdown\":\"# Initialize Variables\\n\\nIn this lesson, you will set up some important attributes for your character in the game.\\n\\n### Challenge\\n\\nYour task is to initialize the following variables that represent your character's stats:\\n- `k`: The level of your character, set to 88.\\n- `PI`: A special magic number representing your character's unique ability, set to 3.14.\\n- `name`: The name of your character, set to \\\"Bob\\\".\\n\\nMake sure to use the exact variable names and values as given. Remember, Python is case-sensitive, so pay attention to the spelling and capitalization!\\n\\n### Code Template\\n\\n```python\\n# Initialize your character's attributes here\\nk = 88  # Value representing your character's level\\nPI = 3.14  # Value representing a special magic number\\nname = 'Bob'  # Your character's name\\n\\n# Don't change the line below\\nprint(f'Level = {k}')\\nprint(f'Magic Number = {PI}')\\nprint(f'Character Name = {name}')\\n```\\n\",\"lesson_typescript\":\"import { useEffect } from \\\"react\\\";\\n\\nimport { useLessonStore } from \\\"@/store/lessonStore\\\";\\nimport { useTraceFinished } from \\\"@/utils/taskChecks\\\";\\n\\nimport content from \\\"./initialize-variables.md?raw\\\";\\n\\nexport function useInitializeVariables(lessonId: string) {\\n  const { startLesson, completeTask, currentTask } = useLessonStore();\\n  const traceFinished = useTraceFinished();\\n\\n  useEffect(() => {\\n    if (lessonId !== \\\"initialize-variables\\\") return;\\n    // Start the lesson\\n    startLesson(lessonId, content, [\\n      {\\n        id: \\\"initialize-attributes\\\",\\n        title: \\\"Initialize the attributes\\\",\\n        description: \\\"Set your character's attributes as specified.\\\",\\n      },\\n    ]);\\n  }, [lessonId, startLesson]);\\n\\n  useEffect(() => {\\n    if (currentTask?.id === \\\"initialize-attributes\\\") {\\n      if (traceFinished) {\\n        completeTask();\\n      }\\n    }\\n  }, [currentTask, completeTask, traceFinished]);\\n}\\n\"}"