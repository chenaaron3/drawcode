  "metadata": {
    "code": "def removeDuplicates(nums):\n    if not nums:\n        return 0\n    # Pointer for the position of the last unique element\n    i = 0\n    for j in range(1, len(nums)):\n        if nums[j] != nums[i]:\n            i += 1\n            nums[i] = nums[j]\n    return i + 1\n",
